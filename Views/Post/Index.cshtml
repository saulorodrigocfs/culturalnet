@model List<ModelPost.Post>

<h1>Feed da Comunidade</h1>

<a class="btn btn-primary mb-3" href="/Post/Create">Criar novo post</a>

<hr>

@foreach (var post in Model)
{
    <div class="card mb-3">
        <div class="card-body">

            <h3>@post.Title</h3>

            <p>
                <strong>Categoria:</strong> @post.Category
            </p>

            <p>@post.Content</p>

            @if (post.ImagePath != null)
            {
                <img src="@post.ImagePath" class="img-fluid rounded mb-2" style="max-width:400px;" />
            }

            <p>
                <small class="text-muted">@post.CreatedAt</small>
            </p>

        </div>
    </div>
}